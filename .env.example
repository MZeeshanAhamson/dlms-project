# Runtime database (use a pooled PostgreSQL URL on Vercel)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dlms
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/dlms_test

# Auth.js
AUTH_SECRET=replace-with-at-least-32-characters
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# Private S3-compatible storage (used from Milestone 2)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dlms-private
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
PHOTO_MAX_BYTES=5242880
DOCUMENT_MAX_BYTES=10485760

# Demo records are opt-in and must never be enabled in production.
SEED_DEMO_USERS=false
DEMO_USER_PASSWORD=
